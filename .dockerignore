# Build artifacts
target/
debug/

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# Documentation
docs/
*.md
!README.md

# CI/CD
.github/

# Deploy configs (not needed in image)
deploy/

# Development files
.editorconfig
.env*
Makefile
rust-toolchain.toml

# Tests (kept out of the runtime image, but tests/integration is a workspace
# member whose manifest must stay in the build context for cargo to parse it)
tests/
examples/
**/tests/
**/*_test.rs
!tests/integration/

# Misc
*.log
coverage/
